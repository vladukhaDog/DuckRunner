<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "2630"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES"
      buildArchitectures = "Automatic">
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "NO"
            buildForArchiving = "NO"
            buildForAnalyzing = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "61399C612F41223F008A0F49"
               BuildableName = "Routka.app"
               BlueprintName = "Routka"
               ReferencedContainer = "container:Routka.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES">
      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Run Script"
               scriptText = "set -eu&#10;&#10;LOG_FILE=&quot;/tmp/routka_marketing_screenshots_post_action.log&quot;&#10;exec &gt;&quot;$LOG_FILE&quot; 2&gt;&amp;1&#10;&#10;echo &quot;========== post-action started ==========&quot;&#10;date&#10;echo &quot;PWD=$PWD&quot;&#10;echo &quot;PROJECT_DIR=${PROJECT_DIR:-&lt;unset&gt;}&quot;&#10;echo &quot;HOME=${HOME:-&lt;unset&gt;}&quot;&#10;&#10;derived_data_root=&quot;${HOME}/Library/Developer/Xcode/DerivedData&quot;&#10;scheme_name=&quot;MarketingScreenshotsRun&quot;&#10;output_dir=&quot;${HOME}/Desktop/RoutkaMarketing&quot;&#10;recent_limit=&quot;${ROUTKA_SCREENSHOT_XCRESULT_LIMIT:-10}&quot;&#10;recent_window_seconds=&quot;${ROUTKA_SCREENSHOT_LOOKBACK_SECONDS:-43200}&quot;&#10;current_epoch=&quot;$(date +%s)&quot;&#10;&#10;echo &quot;derived_data_root=$derived_data_root&quot;&#10;echo &quot;scheme_name=$scheme_name&quot;&#10;echo &quot;output_dir=$output_dir&quot;&#10;echo &quot;recent_limit=$recent_limit&quot;&#10;echo &quot;recent_window_seconds=$recent_window_seconds&quot;&#10;&#10;echo &quot;waiting briefly so Xcode can finish writing the result bundle&quot;&#10;sleep 5&#10;&#10;temp_root=&quot;$(mktemp -d /tmp/routka_marketing_export.XXXXXX)&quot;&#10;cleanup() {&#10;  rm -rf &quot;$temp_root&quot;&#10;}&#10;trap cleanup EXIT&#10;&#10;xcresult_list=&quot;$temp_root/xcresults.txt&quot;&#10;: &gt; &quot;$xcresult_list&quot;&#10;&#10;attempt=1&#10;while [ &quot;$attempt&quot; -le 30 ]; do&#10;  echo &quot;search attempt $attempt&quot;&#10;&#10;  find &quot;$derived_data_root&quot; -path &quot;*/Logs/Test/Test-${scheme_name}-*.xcresult&quot; -print 2&gt;/dev/null |&#10;  while IFS= read -r path; do&#10;    if [ -f &quot;$path/Info.plist&quot; ]; then&#10;      modified=&quot;$(stat -f &quot;%m&quot; &quot;$path&quot;)&quot;&#10;      age=$((current_epoch - modified))&#10;      if [ &quot;$age&quot; -le &quot;$recent_window_seconds&quot; ]; then&#10;        printf &quot;%s\t%s\n&quot; &quot;$modified&quot; &quot;$path&quot;&#10;      fi&#10;    fi&#10;  done |&#10;  sort -rn |&#10;  head -n &quot;$recent_limit&quot; |&#10;  cut -f2- &gt; &quot;$xcresult_list&quot;&#10;&#10;  if [ -s &quot;$xcresult_list&quot; ]; then&#10;    echo &quot;xcresult bundles ready:&quot;&#10;    cat &quot;$xcresult_list&quot;&#10;    break&#10;  fi&#10;&#10;  : &gt; &quot;$xcresult_list&quot;&#10;  attempt=$((attempt + 1))&#10;  sleep 1&#10;done&#10;&#10;if [ ! -s &quot;$xcresult_list&quot; ]; then&#10;  echo &quot;No ready xcresults found for $scheme_name&quot;&#10;  exit 1&#10;fi&#10;&#10;rm -rf &quot;$output_dir&quot;&#10;mkdir -p &quot;$output_dir&quot;&#10;&#10;found_matching_attachments=0&#10;processed_xcresults=0&#10;&#10;while IFS= read -r xcresult_path; do&#10;  [ -n &quot;$xcresult_path&quot; ] || continue&#10;&#10;  processed_xcresults=$((processed_xcresults + 1))&#10;  export_dir=&quot;$temp_root/export_$processed_xcresults&quot;&#10;  manifest_path=&quot;$export_dir/manifest.json&quot;&#10;&#10;  echo &quot;processing xcresult: $xcresult_path&quot;&#10;  mkdir -p &quot;$export_dir&quot;&#10;&#10;  export_attempt=1&#10;  while [ &quot;$export_attempt&quot; -le 10 ]; do&#10;    echo &quot;export attempt $export_attempt for xcresult #$processed_xcresults&quot;&#10;    rm -rf &quot;$export_dir&quot;&#10;    mkdir -p &quot;$export_dir&quot;&#10;&#10;    if /usr/bin/xcrun xcresulttool export attachments \&#10;      --path &quot;$xcresult_path&quot; \&#10;      --output-path &quot;$export_dir&quot;; then&#10;      echo &quot;export finished for $xcresult_path&quot;&#10;    else&#10;      echo &quot;attachment export failed for $xcresult_path&quot;&#10;    fi&#10;&#10;    if [ -f &quot;$manifest_path&quot; ] &amp;&amp; /usr/bin/jq -e &apos;length &gt; 0&apos; &quot;$manifest_path&quot; &gt;/dev/null; then&#10;      echo &quot;attachment manifest is ready for $xcresult_path&quot;&#10;      break&#10;    fi&#10;&#10;    echo &quot;attachment manifest is empty or missing for $xcresult_path&quot;&#10;    export_attempt=$((export_attempt + 1))&#10;    sleep 1&#10;  done&#10;&#10;  if [ ! -f &quot;$manifest_path&quot; ]; then&#10;    echo &quot;manifest.json missing for $xcresult_path&quot;&#10;    continue&#10;  fi&#10;&#10;  if ! /usr/bin/jq -e &apos;.[] | select(.testIdentifier | contains(&quot;RoutkaMarketingScreenshotUITests/&quot;))&apos; &quot;$manifest_path&quot; &gt;/dev/null; then&#10;    echo &quot;No RoutkaMarketingScreenshotUITests entries found in $xcresult_path&quot;&#10;    continue&#10;  fi&#10;&#10;  found_matching_attachments=1&#10;  echo &quot;manifest contents for $xcresult_path:&quot;&#10;  cat &quot;$manifest_path&quot;&#10;&#10;  /usr/bin/jq -r &apos;&#10;    .[]&#10;    | select(.testIdentifier | contains(&quot;RoutkaMarketingScreenshotUITests/&quot;))&#10;    | .attachments[]&#10;    | [.exportedFileName, .suggestedHumanReadableName]&#10;    | @tsv&#10;  &apos; &quot;$manifest_path&quot; |&#10;  while IFS=&quot;$(printf &apos;\t&apos;)&quot; read -r from to; do&#10;    echo &quot;copy candidate from $xcresult_path: $from -&gt; $to&quot;&#10;&#10;    if [ -z &quot;$from&quot; ] || [ -z &quot;$to&quot; ]; then&#10;      echo &quot;skipping invalid copy entry&quot;&#10;      continue&#10;    fi&#10;&#10;    source_path=&quot;$export_dir/$from&quot;&#10;    destination_path=&quot;$output_dir/$to&quot;&#10;&#10;    if [ ! -f &quot;$source_path&quot; ]; then&#10;      echo &quot;source file missing: $source_path&quot;&#10;      continue&#10;    fi&#10;&#10;    if [ -e &quot;$destination_path&quot; ]; then&#10;      echo &quot;destination exists, replacing older file: $destination_path&quot;&#10;      rm -f &quot;$destination_path&quot;&#10;    fi&#10;&#10;    cp &quot;$source_path&quot; &quot;$destination_path&quot;&#10;    echo &quot;copied to $destination_path&quot;&#10;  done&#10;done &lt; &quot;$xcresult_list&quot;&#10;&#10;if [ &quot;$found_matching_attachments&quot; -ne 1 ]; then&#10;  echo &quot;No screenshot attachments found across recent xcresults&quot;&#10;  exit 0&#10;fi&#10;&#10;echo &quot;final output:&quot;&#10;ls -la &quot;$output_dir&quot; || true&#10;&#10;echo &quot;Processed xcresults:&quot;&#10;cat &quot;$xcresult_list&quot;&#10;&#10;echo &quot;Log file: $LOG_FILE&quot;&#10;echo &quot;========== post-action finished ==========&quot;&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "61E99E202F85B1140087320E"
                     BuildableName = "MarketingScreenshotsRun.xctest"
                     BlueprintName = "MarketingScreenshotsRun"
                     ReferencedContainer = "container:Routka.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
      <TestPlans>
         <TestPlanReference
            reference = "container:MarketingScreenshots.xctestplan"
            default = "YES">
         </TestPlanReference>
      </TestPlans>
   </TestAction>
