    "speedtrap replay hint %@ %@" : {
      "comment" : "A hint explaining the speed required to start a speedtrap replay. First argument is the speed value. The second argument is the string speed unit",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To initiate the recording you should drive through the start zone at %1$@ %2$@and the recording will start automatically.\nDriving trough the stop zone stops the replay and saves the result.\nWarning: Stopping the recording early saves the track as a standalone recording"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы начать запись повтора, нужно проехать через зону старта cо скоростью %1$@ %2$@, запись начнется автоматически.\nЧтобы завершить повтор - нужно проехать зону финиша.\nВнимание: Остановка записи до финиша сохранит маршрут как отдельную запись"
          }
        }
      }
    },
