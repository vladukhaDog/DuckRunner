    },
    "%@ Track" : {
      "comment" : "The title of the view, showing the date of the track.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поездка %@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "The current value of the start handle, displayed as text.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "🔥" : {
      "comment" : "A fire emoji used to indicate a top speed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🔥"
          }
        }
      }
    },
    "avg" : {
      "comment" : "A label displayed next to a speed value to indicate that it is an average.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "avg"
          }
        }
      }
    },
    "Bring in .routka saved files." : {
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузите .routka файлы."
          }
        }
      }
    },
    "Browse recorded runs, compare measurements, and jump back into imported sessions." : {
      "comment" : "Journal description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browse recorded runs, compare measurements, and jump back into imported sessions."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Просматривайте записанные поездки, смотрите результаты замеры и возвращайтесь к загруженным маршрутам."
          }
        }
      }
    },
    "By accessing or using this application, you represent, acknowledge, and agree that you are solely responsible for operating your vehicle safely and in full compliance with all applicable traffic laws and regulations.\n\nDo not use your mobile device while the vehicle is in motion.\nAlways obey posted speed limits.\nAvoid aggressive or reckless maneuvers.\n\nFailure to comply with traffic laws may result in serious injury, death, or legal consequences.\n\nIf you wish to engage in high-speed or competitive driving, please do so only at authorized racing facilities." : {
      "comment" : "A disclaimer text displayed within the disclaimer overlay.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пользуясь этим приложением, вы подтверждаете, и соглашаетесь с тем, что несете ответственность за безопасное управление своим транспортным средством в полном соответствии со всеми нормами и правилами дорожного движения.\n\nНе используйте мобильное устройство во время движения.\nВсегда соблюдайте установленные скоростные ограничения.\nИзбегайте агрессивных или опасных маневров.\n\nНесоблюдение правил дорожного движения может привести к серьезным травмам, смерти или юридическим последствиям.\n\nЕсли вы хотите участвовать в скоростных или соревновательных заездах, пожалуйста, делайте это только на официально разрешенных гоночных трассах."
          }
        }
      }
    },
    "Checkpoint Distance Activate Threshold" : {
      "comment" : "A section that allows the user to set a threshold for the distance between a checkpoint and the current location, which will trigger a checkpoint update.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "Checkpoint Distance Interval" : {
      "comment" : "A section header that describes the checkpoint distance interval setting.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "Choose the measurement to record" : {
      "comment" : "A label displayed above the list of track presets.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите замер для записи"
          }
        }
      }
    },
    "classical" : {
      "comment" : "track replay mode localized name",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Classical replay"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повтор с места"
          }
        }
      }
    },
    "classical replay hint" : {
      "comment" : "A hint text for a classical replay mode.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To initiate the recording you should drive to the start zone and stop the vehicle.\nAfter the speed is low enough, the manual Start button will be available to tap.\nDriving trough the stop zone stops the replay and saves the result.\nWarning: Stopping the recording early saves the track as a standalone recording"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы начать запись повтора, нужно заехать в зону старта и остановить автомобиль.\nПосле полной остановки, будет доступна кнопка старта записи.\nЧтобы завершить повтор - нужно проехать зону финиша.\nВнимание: Остановка записи до финиша сохранит маршрут как отдельную запись"
          }
        }
      }
    },
    "Date" : {
